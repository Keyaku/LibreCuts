<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_nav_floating"
            android:padding="24dp"
            android:elevation="12dp">

            <!-- App Logo and Title header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/ivOnboardingLogo"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="LibreCuts App Icon" />

                <TextView
                    android:id="@+id/tvOnboardingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LibreCuts"
                    android:textColor="@color/textColor"
                    android:textSize="24sp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvOnboardingVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version 1.0"
                    android:textColor="@color/inactiveTool"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Free. Open-Source. Limitless."
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Links list -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMUNITY &amp; SUPPORT"
                android:textColor="@color/inactiveTool"
                android:textSize="10sp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium" />

            <!-- Link: Star on GitHub -->
            <LinearLayout
                android:id="@+id/layoutStarGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_aspect_ratio_item"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_github_24"
                    app:tint="@color/textColor" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Star on GitHub"
                        android:textColor="@color/textColor"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show your appreciation by starring the repo"
                        android:textColor="@color/inactiveTool"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Link: GitHub Sponsor -->
            <LinearLayout
                android:id="@+id/layoutSponsorGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_aspect_ratio_item"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_heart_24"
                    app:tint="#E91E63" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GitHub Sponsors"
                        android:textColor="@color/textColor"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Support our open source development directly"
                        android:textColor="@color/inactiveTool"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Link: Discord -->
            <LinearLayout
                android:id="@+id/layoutDiscord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_aspect_ratio_item"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_discord_24"
                    app:tint="@color/colorSecondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Discord Server"
                        android:textColor="@color/textColor"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Join us for app updates and community chat"
                        android:textColor="@color/inactiveTool"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Troubleshooting section -->
            <LinearLayout
                android:id="@+id/layoutTroubleshooting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_aspect_ratio_item"
                android:backgroundTint="#1AFFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="12dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info_24"
                        app:tint="@color/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Troubleshooting &amp; Wiki Guide"
                        android:textColor="@color/textColor"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If you encounter any export issues or rendering errors, tap here to read our wiki guide for troubleshooting and error codes."
                    android:textColor="@color/inactiveTool"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.1" />
            </LinearLayout>

            <!-- Done/Dismiss button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOnboardingGetStarted"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Get Started"
                android:textColor="@color/onPrimaryContainer"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
